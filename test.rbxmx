      <Item class="ModuleScript" referent="3">
        <Properties>
          <string name="Name">RNGSystem</string>
          <string name="Source">--[[
	RNG System Module
	Handles the weighted random selection of items based on rarity
]]

local RNGConfig = require(script.Parent.RNGConfig)

local RNGSystem = {}

-- Create a weighted table for efficient random selection
local function createWeightedTable()
	local weightedTable = {}

	for _, rarity in ipairs(RNGConfig.Rarities) do
		table.insert(weightedTable, {
			Name = rarity.Name,
			Chance = rarity.Chance,
			Color = rarity.Color
		})
	end

	return weightedTable
end

-- Select a random rarity based on weighted chances
function RNGSystem.SelectRarity()
	local weightedTable = createWeightedTable()
	local totalWeight = 0

	-- Calculate total weight
	for _, rarity in ipairs(weightedTable) do
		totalWeight = totalWeight + rarity.Chance
	end

	-- Generate random number
	local random = math.random() * totalWeight
	local currentWeight = 0

	-- Select rarity based on weight
	for _, rarity in ipairs(weightedTable) do
		currentWeight = currentWeight + rarity.Chance
		if random &lt;= currentWeight then
			return rarity
		end
	end

	-- Fallback to first rarity (should never happen)
	return weightedTable[1]
end

-- Select a random item from a specific rarity
function RNGSystem.SelectItem(rarityName)
	local items = RNGConfig.Items[rarityName]

	if not items or #items == 0 then
		warn("No items found for rarity: " .. rarityName)
		return nil
	end

	local randomIndex = math.random(1, #items)
	return items[randomIndex]
end

-- Perform a complete roll (rarity + item)
function RNGSystem.PerformRoll()
	local rarity = RNGSystem.SelectRarity()
	local item = RNGSystem.SelectItem(rarity.Name)

	if not item then
		-- Fallback to common if something goes wrong
		rarity = RNGConfig.Rarities[1]
		item = RNGConfig.Items.Common[1]
	end

	-- Calculate total weight for percentage
	local totalWeight = 0
	for _, r in ipairs(RNGConfig.Rarities) do
		totalWeight = totalWeight + r.Chance
	end

	-- Calculate actual percentage chance
	local rarityChance = (rarity.Chance / totalWeight) * 100

	return {
		Rarity = rarity.Name,
		RarityColor = rarity.Color,
		RarityChance = rarityChance,
		ItemName = item.Name,
		ItemDescription = item.Description,
		Timestamp = os.time()
	}
end

-- Get rarity information by name
function RNGSystem.GetRarityInfo(rarityName)
	for _, rarity in ipairs(RNGConfig.Rarities) do
		if rarity.Name == rarityName then
			return rarity
		end
	end
	return nil
end

-- Calculate luck multiplier (can be used for game passes, etc.)
function RNGSystem.PerformRollWithLuck(luckMultiplier)
	luckMultiplier = luckMultiplier or 1

	-- Adjust chances based on luck (makes rare items more common)
	local adjustedRarities = {}
	for i, rarity in ipairs(RNGConfig.Rarities) do
		local adjustedChance = rarity.Chance

		-- Increase chances for rarer items with luck
		if i &gt; 3 then -- Only affect rare and above
			adjustedChance = adjustedChance * luckMultiplier
		end

		table.insert(adjustedRarities, {
			Name = rarity.Name,
			Chance = adjustedChance,
			Color = rarity.Color
		})
	end

	-- Normalize chances to maintain 100% total
	local totalChance = 0
	for _, rarity in ipairs(adjustedRarities) do
		totalChance = totalChance + rarity.Chance
	end

	local random = math.random() * totalChance
	local currentWeight = 0

	for _, rarity in ipairs(adjustedRarities) do
		currentWeight = currentWeight + rarity.Chance
		if random &lt;= currentWeight then
			local item = RNGSystem.SelectItem(rarity.Name)

			return {
				Rarity = rarity.Name,
				RarityColor = rarity.Color,
				RarityChance = (RNGConfig.Rarities[table.find(RNGConfig.Rarities, 
					function(r) return r.Name == rarity.Name end) or 1].Chance / totalChance) * 100,
				ItemName = item.Name,
				ItemDescription = item.Description,
				Timestamp = os.time()
			}
		end
	end

	-- Fallback
	return RNGSystem.PerformRoll()
end

return RNGSystem</string>
        </Properties>
      </Item>
    </Item>
    <Item class="ServerScriptService" referent="4">
      <Properties>
        <string name="Name">ServerScriptService</string>
      </Properties>
      <Item class="Script" referent="5">
        <Properties>
          <string name="Name">CraftingServer</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- CraftingServer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local CraftingEvent = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("CraftingEvent")
local InventoryUpdateEvent = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("InventoryUpdateEvent")

local CraftingRecipes = require(ReplicatedStorage:WaitForChild("CraftingRecipes"))
local PlayerDataManager = require(game.ServerScriptService:WaitForChild("PlayerDataManager"))

local function CanCraft(player, recipe)
	local inv = PlayerDataManager.GetInventory(player)
	local inventoryLookup = {}
	for _, item in ipairs(inv) do
		local key = item.ItemName .. "|" .. item.Rarity
		inventoryLookup[key] = (inventoryLookup[key] or 0) + (item.Quantity or 1)
	end
	for _, ing in ipairs(recipe.Ingredients) do
		local key = ing.Name .. "|" .. ing.Rarity
		if (inventoryLookup[key] or 0) < ing.Quantity then
			return false
		end
	end
	return true
end

local function ApplyCraft(player, recipe)
	local data = PlayerDataManager.GetData(player)
	local inv = data.Inventory

	local inventoryLookup = {}
	for i, item in ipairs(inv) do
		local key = item.ItemName .. "|" .. item.Rarity
		if not inventoryLookup[key] then
			inventoryLookup[key] = {quantity = 0, indices = {}}
		end
		inventoryLookup[key].quantity += (item.Quantity or 1)
		table.insert(inventoryLookup[key].indices, i)
	end

	for _, ing in ipairs(recipe.Ingredients) do
		local key = ing.Name .. "|" .. ing.Rarity
		local needed = ing.Quantity
		local lookup = inventoryLookup[key]
		if lookup then
			for _, index in ipairs(lookup.indices) do
				if needed <= 0 then break end
				local item = inv[index]
				local available = item.Quantity or 1
				local toRemove = math.min(available, needed)
				item.Quantity = available - toRemove
				needed -= toRemove
				if item.Quantity <= 0 then
					item._remove = true
				end
			end
		end
	end

	for i = #inv, 1, -1 do
		if inv[i]._remove then
			if data.EquippedIndex == i then
				data.EquippedIndex = nil
			elseif data.EquippedIndex and data.EquippedIndex > i then
				data.EquippedIndex -= 1
			end
			table.remove(inv, i)
		end
	end

	local resultFound = false
	for _, item in ipairs(inv) do
		if item.ItemName == recipe.Result.Name and item.Rarity == recipe.Result.Rarity then
			item.Quantity = (item.Quantity or 1) + 1
			item.IsCrafted = true
			item.Description = recipe.Result.Description
			resultFound = true
			break
		end
	end

	if not resultFound then
		table.insert(inv, {
			ItemName = recipe.Result.Name,
			Rarity = recipe.Result.Rarity,
			Description = recipe.Result.Description,
			Quantity = 1,
			Equipped = false,
			IsCrafted = true
		})
	end

	PlayerDataManager.SaveData(player)

	if _G.sendFullUpdate then
		_G.sendFullUpdate(player)
	end
end

CraftingEvent.OnServerEvent:Connect(function(player, recipeIndex)
	local recipes = CraftingRecipes.Recipes
	if not recipes or not recipes[recipeIndex] then
		CraftingEvent:FireClient(player, {Success = false, Message = "Recipe not found"})
		return
	end
	local recipe = recipes[recipeIndex]
	if CanCraft(player, recipe) then
		ApplyCraft(player, recipe)
		CraftingEvent:FireClient(player, {Success = true, Result = recipe.Result})
	else
		CraftingEvent:FireClient(player, {Success = false, Message = "Not enough ingredients"})
	end
end)

print("[CraftingServer] Initialized")
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="6">
        <Properties>
          <string name="Name">GiveAllMaterialsHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- GiveAllMaterialsHandler (Server Script - Owner Only)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local PlayerDataManager = require(script.Parent:WaitForChild("PlayerDataManager"))
local RNGConfig = require(ReplicatedStorage:WaitForChild("RNGConfig"))

local RemoteEventsFolder = ReplicatedStorage:WaitForChild("RemoteEvents")
local GiveAllMaterialsEvent = RemoteEventsFolder:WaitForChild("GiveAllMaterialsEvent")

GiveAllMaterialsEvent.OnServerEvent:Connect(function(player)
	if player.UserId ~= game.CreatorId then
		GiveAllMaterialsEvent:FireClient(player, {Success = false, Message = "Only the server owner can use this feature"})
		return
	end

	local data = PlayerDataManager.GetData(player)
	if not data then
		GiveAllMaterialsEvent:FireClient(player, {Success = false, Message = "No player data found"})
		return
	end

	local addedCount = 0
	local currentTime = os.time()

	for rarityName, items in pairs(RNGConfig.Items) do
		for _, itemData in ipairs(items) do
			local rollResult = {
				ItemName = itemData.Name,
				Rarity = rarityName,
				ItemDescription = itemData.Description,
				Timestamp = currentTime
			}
			if PlayerDataManager.AddItemToInventory(player, rollResult) then
				addedCount += 1
			end
		end
	end

	PlayerDataManager.SaveData(player)
	GiveAllMaterialsEvent:FireClient(player, {Success = true, Message = "Added " .. addedCount .. " materials!"})
end)

print("[GiveAllMaterialsHandler] Initialized")
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="7">
        <Properties>
          <string name="Name">ItemDisplayAnimation</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- ItemDisplayAnimation (Server Script)
-- Animates items placed on pedestals with floating + spinning
local TweenService = game:GetService("TweenService")

local function animateItemDisplay(itemDisplay)
	local basePart = itemDisplay:FindFirstChild("ItemBase")
	if not basePart then return end

	local originalCFrame = basePart.CFrame

	task.spawn(function()
		while itemDisplay and itemDisplay.Parent do
			local floatUp = TweenService:Create(basePart, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				CFrame = originalCFrame * CFrame.new(0, 0.5, 0)
			})
			local floatDown = TweenService:Create(basePart, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				CFrame = originalCFrame
			})

			floatUp:Play()
			floatUp.Completed:Wait()
			if not (itemDisplay and itemDisplay.Parent) then break end

			floatDown:Play()
			floatDown.Completed:Wait()
			if not (itemDisplay and itemDisplay.Parent) then break end
		end
	end)
end

-- Watch all Item Stand models in workspace
local function watchModel(model)
	if not model:IsA("Model") then return end
	model.DescendantAdded:Connect(function(descendant)
		if descendant.Name == "ItemBase" and descendant:IsA("Part") then
			task.wait(0.5)
			animateItemDisplay(descendant.Parent)
		end
	end)
	-- Animate existing items
	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == "ItemBase" and descendant:IsA("Part") then
			animateItemDisplay(descendant.Parent)
		end
	end
end

for _, child in ipairs(workspace:GetChildren()) do
	watchModel(child)
end
workspace.ChildAdded:Connect(watchModel)

print("[ItemDisplayAnimation] Initialized")
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="8">
        <Properties>
          <string name="Name">MoneySystem</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- MoneySystem (Server Script)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local PlayerDataManager = require(script.Parent.PlayerDataManager)
local RNGConfig = require(ReplicatedStorage:WaitForChild("RNGConfig"))

local MoneyConfig = {
	BaseIncomeRate = 1,
	IncomeInterval = 1,
}

local incomeTasks = {}

local rarityMultiplier = {
	Common = 1, Uncommon = 1.5, Rare = 2, Epic = 3,
	Legendary = 5, Mythical = 8, Divine = 12, Exotic = 18, Celestial = 25,
}

local function calculateIncomeRate(player)
	local data = PlayerDataManager.GetData(player)
	if not data then return MoneyConfig.BaseIncomeRate end
	for _, item in ipairs(data.Inventory) do
		if item.Equipped then
			return MoneyConfig.BaseIncomeRate * (rarityMultiplier[item.Rarity] or 1)
		end
	end
	return MoneyConfig.BaseIncomeRate
end

local RemoteEventsFolder = ReplicatedStorage:WaitForChild("RemoteEvents")
local MoneyUpdateEvent = RemoteEventsFolder:WaitForChild("MoneyUpdateEvent")

local function giveMoney(player)
	local rate = calculateIncomeRate(player)
	if rate > 0 then
		PlayerDataManager.AddCurrency(player, rate)
		MoneyUpdateEvent:FireClient(player, {
			Amount = rate,
			Total = PlayerDataManager.GetCurrency(player),
			IncomeRate = rate
		})
	end
end

local function startIncome(player)
	if incomeTasks[player.UserId] then
		task.cancel(incomeTasks[player.UserId])
	end
	incomeTasks[player.UserId] = task.spawn(function()
		while true do
			task.wait(MoneyConfig.IncomeInterval)
			if player and player.Parent == Players then
				giveMoney(player)
			else
				break
			end
		end
	end)
end

local function stopIncome(player)
	if incomeTasks[player.UserId] then
		task.cancel(incomeTasks[player.UserId])
		incomeTasks[player.UserId] = nil
	end
end

Players.PlayerAdded:Connect(function(player)
	task.wait(1)
	startIncome(player)
end)

Players.PlayerRemoving:Connect(function(player)
	stopIncome(player)
	PlayerDataManager.SaveData(player)
end)

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(function()
		task.wait(1)
		startIncome(player)
	end)
end

local GetMoneyFunction = RemoteEventsFolder:WaitForChild("GetMoneyFunction")
GetMoneyFunction.OnServerInvoke = function(player)
	return PlayerDataManager.GetCurrency(player)
end

local EquipEvent = RemoteEventsFolder:WaitForChild("EquipEvent")
EquipEvent.OnServerEvent:Connect(function(player)
	task.wait(0.5)
	startIncome(player)
end)

print("[MoneySystem] Initialized")
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="9">
        <Properties>
          <string name="Name">PedestalPlacementSystem</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- PedestalPlacementSystem (Server Script)
-- Handles ProximityPrompt interaction + crafted item placement on pedestals

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local RemoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")

-- Create or reuse PlaceItemOnPedestal event
local PlaceItemEvent = RemoteEvents:FindFirstChild("PlaceItemOnPedestal")
if not PlaceItemEvent then
	PlaceItemEvent = Instance.new("RemoteEvent")
	PlaceItemEvent.Name = "PlaceItemOnPedestal"
	PlaceItemEvent.Parent = RemoteEvents
end

-- Create or reuse OpenPedestalSelection event
local OpenPedestalSelectionEvent = RemoteEvents:FindFirstChild("OpenPedestalSelection")
if not OpenPedestalSelectionEvent then
	OpenPedestalSelectionEvent = Instance.new("RemoteEvent")
	OpenPedestalSelectionEvent.Name = "OpenPedestalSelection"
	OpenPedestalSelectionEvent.Parent = RemoteEvents
end

local PlayerDataManager = require(game.ServerScriptService:WaitForChild("PlayerDataManager"))

-- Store placed item models per pedestal so we can clear them when replaced
local placedItems = {}

-- Rarity color table
local rarityColors = {
	Common    = Color3.fromRGB(150, 150, 150),
	Uncommon  = Color3.fromRGB(50, 200, 50),
	Rare      = Color3.fromRGB(50, 100, 255),
	Epic      = Color3.fromRGB(200, 50, 200),
	Legendary = Color3.fromRGB(255, 200, 50),
	Mythical  = Color3.fromRGB(255, 100, 50),
	Divine    = Color3.fromRGB(255, 255, 255),
	Exotic    = Color3.fromRGB(100, 255, 255),
	Celestial = Color3.fromRGB(150, 100, 255),
}

-- Builds the visual 3D item. Ensures it has a PrimaryPart for pivoting.
local function createItemDisplay(itemName, itemRarity)
	local displayModel = Instance.new("Model")
	displayModel.Name = itemName .. "_Display"

	local basePart = Instance.new("Part")
	basePart.Name = "ItemBase"
	basePart.Anchored = true
	basePart.CanCollide = false

	-- Determine geometric shape based on item name keywords
	if itemName:find("Steel") or itemName:find("Bronze") or itemName:find("Alloy") or itemName:find("Metal") or itemName == "Iron" or itemName == "Copper" then
		basePart.Shape    = Enum.PartType.Block
		basePart.Size     = Vector3.new(2.5, 1, 1.2)
		basePart.Material = Enum.Material.Metal
	elseif itemName == "Water" or itemName:find("Crystal") or itemName:find("Essence") or itemName == "Salt" then
		basePart.Shape        = Enum.PartType.Ball
		basePart.Size         = Vector3.new(2, 2, 2)
		basePart.Material     = Enum.Material.Glass
		basePart.Transparency = 0.4
		basePart.Reflectance  = 0.5
	else
		basePart.Shape    = Enum.PartType.Ball
		basePart.Size     = Vector3.new(2, 2, 2)
		basePart.Material = Enum.Material.Neon
	end

	basePart.Color  = rarityColors[itemRarity] or rarityColors.Common
	basePart.Parent = displayModel
	
	-- Critical fix: Set PrimaryPart so :PivotTo() works perfectly
	displayModel.PrimaryPart = basePart

	-- Glow effect
	local light = Instance.new("PointLight")
	light.Color      = basePart.Color
	light.Brightness = 3
	light.Range      = 10
	light.Parent     = basePart

	-- Billboard GUI for item name
	local billboard = Instance.new("BillboardGui")
	billboard.Size         = UDim2.new(5, 0, 1.2, 0)
	billboard.StudsOffset  = Vector3.new(0, 3, 0)
	billboard.AlwaysOnTop  = true
	billboard.Adornee      = basePart
	billboard.Parent       = displayModel

	local label = Instance.new("TextLabel")
	label.Size               = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text               = itemName
	label.TextColor3         = basePart.Color
	label.TextScaled         = true
	label.Font               = Enum.Font.GothamBold
	label.Parent             = billboard

	-- Particle effect
	local att = Instance.new("Attachment", basePart)
	local particles = Instance.new("ParticleEmitter", att)
	particles.Color       = ColorSequence.new(basePart.Color)
	particles.Size        = NumberSequence.new(0.2, 0.5)
	particles.Lifetime    = NumberRange.new(1, 2)
	particles.Rate        = 20
	particles.Speed       = NumberRange.new(1, 3)
	particles.SpreadAngle = Vector2.new(180, 180)
	particles.Parent      = att

	-- Simple continuous rotation handled by the server
	task.spawn(function()
		while basePart and basePart.Parent do
			basePart.CFrame = basePart.CFrame * CFrame.Angles(0, math.rad(1), 0)
			task.wait()
		end
	end)

	return displayModel
end

-- Core placement logic, completely rewritten for safety
local function placeItemOnPedestal(player, itemStand, itemName)
	-- 1. Validate the Pedestal exists and has a spawn point
	if not itemStand or not itemStand:IsA("Model") then
		warn("[Pedestal] Invalid itemStand passed by", player.Name)
		return
	end

	local equipmentSpawner = itemStand:FindFirstChild("EquipmentSpawner")
	if not equipmentSpawner or not equipmentSpawner:IsA("BasePart") then
		warn("[Pedestal] ItemStand", itemStand.Name, "is missing 'EquipmentSpawner' BasePart.")
		return
	end

	-- 2. Verify Player Inventory & Ownership
	local inventory = PlayerDataManager.GetInventory(player)
	if not inventory then
		warn("[Pedestal] Could not load inventory for", player.Name)
		return
	end

	local itemRarity = "Common"
	local hasItem = false

	for _, item in ipairs(inventory) do
		if item.ItemName == itemName and item.IsCrafted then
			hasItem = true
			itemRarity = item.Rarity or "Common"
			break
		end
	end

	if not hasItem then
		warn("[Pedestal]", player.Name, "attempted to place", itemName, "but doesn't own a crafted version.")
		return
	end

	-- 3. Clear Existing Item
	if placedItems[itemStand] then
		placedItems[itemStand]:Destroy()
		placedItems[itemStand] = nil
	end

	-- 4. Create and Position New Item
	local display = createItemDisplay(itemName, itemRarity)
	
	-- We use PivotTo now that PrimaryPart is guaranteed to be set
	-- Float it exactly 3 studs above the spawner's center point
	display:PivotTo(equipmentSpawner.CFrame * CFrame.new(0, 3, 0))
	display.Parent = itemStand
	
	-- Store reference
	placedItems[itemStand] = display

	print("[Pedestal] Successfully placed", itemName, "on", itemStand.Name, "by", player.Name)
end

-- Network Reception
PlaceItemEvent.OnServerEvent:Connect(function(player, itemStand, itemName)
	placeItemOnPedestal(player, itemStand, itemName)
end)

-- Prompt Setup Function
local function setupPedestal(model)
	if not model:IsA("Model") or model.Name ~= "Item Stand" then return end

	local part = model:FindFirstChild("EquipmentSpawner") 
		or model:FindFirstChild("MainPart") 
		or model:FindFirstChildWhichIsA("BasePart")
		
	if not part then return end
	if part:FindFirstChild("PedestalPrompt") then return end

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name         = "PedestalPrompt"
	prompt.ActionText   = "Manage Pedestal"
	prompt.ObjectText   = "Item Stand"
	prompt.HoldDuration = 0.5
	prompt.RequiresLineOfSight = false
	prompt.MaxActivationDistance = 10
	prompt.Parent       = part

	prompt.Triggered:Connect(function(player)
		local ok, err = pcall(function()
			local inventory = PlayerDataManager.GetInventory(player)
			local craftedItems = {}

			if inventory then
				for _, item in ipairs(inventory) do
					if item.IsCrafted then
						table.insert(craftedItems, item)
					end
				end
			end

			-- Always fire so UI opens, even if empty
			OpenPedestalSelectionEvent:FireClient(player, model, craftedItems)
		end)

		if not ok then
			warn("[PedestalPlacementSystem] Trigger error:", err)
		end
	end)
end

-- Initialize existing pedestals + future ones (handling nested pedestals gracefully)
for _, desc in ipairs(workspace:GetDescendants()) do
	setupPedestal(desc)
end
workspace.DescendantAdded:Connect(setupPedestal)

print("[PedestalPlacementSystem] Completely Rewritten & Initialized")
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="10">
        <Properties>
          <string name="Name">PlayerDataManager</string>
          <string name="Source">--[[
	Player Data Manager
	Handles saving and loading player inventory and roll history
]]

local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local PlayerDataStore = DataStoreService:GetDataStore("PlayerRNGData")

local PlayerDataManager = {}
PlayerDataManager.PlayerData = {}

-- Default data structure for new players
local function getDefaultData()
	return {
		Inventory = {},
		EquippedIndex = nil, -- Index of equipped item or nil
		RollHistory = {},
		TotalRolls = 0,
		LastRollTime = 0,
		Currency = 0, -- Optional currency for roll costs
		LuckMultiplier = 1
	}
end

-- Load player data
function PlayerDataManager.LoadData(player)
	local success, data = pcall(function()
		return PlayerDataStore:GetAsync(player.UserId)
	end)

	if success and data then
		-- Migrate old data format to new format
		if data.EquippedItem ~= nil and data.EquippedIndex == nil then
			print("Migrating old EquippedItem field to EquippedIndex for " .. player.Name)
			data.EquippedIndex = data.EquippedItem
			data.EquippedItem = nil
		end
		
		-- Ensure all inventory items have IsCrafted field
		if data.Inventory then
			for _, item in ipairs(data.Inventory) do
				if item.IsCrafted == nil then
					item.IsCrafted = false -- Default to false for existing items
				end
			end
		end
		
		PlayerDataManager.PlayerData[player.UserId] = data
		print("Loaded data for " .. player.Name)
	else
		PlayerDataManager.PlayerData[player.UserId] = getDefaultData()
		print("Created new data for " .. player.Name)
	end

	return PlayerDataManager.PlayerData[player.UserId]
end

-- Save player data
function PlayerDataManager.SaveData(player)
	local data = PlayerDataManager.PlayerData[player.UserId]

	if not data then
		warn("No data to save for " .. player.Name)
		return false
	end

	local success, err = pcall(function()
		PlayerDataStore:SetAsync(player.UserId, data)
	end)

	if success then
		print("Saved data for " .. player.Name)
		return true
	else
		warn("Failed to save data for " .. player.Name .. ": " .. tostring(err))
		return false
	end
end

-- Get player data
function PlayerDataManager.GetData(player)
	return PlayerDataManager.PlayerData[player.UserId]
end

-- Add item to player inventory (with stacking)
function PlayerDataManager.AddItemToInventory(player, rollResult)
	local data = PlayerDataManager.GetData(player)

	if not data then
		warn("No data found for " .. player.Name)
		return false
	end

	-- Check if item already exists (same name and rarity)
	for _, item in ipairs(data.Inventory) do
		if item.ItemName == rollResult.ItemName and item.Rarity == rollResult.Rarity then
			-- Increment quantity instead of adding new entry
			item.Quantity = (item.Quantity or 1) + 1
			print("Stacked " .. rollResult.ItemName .. " (now x" .. item.Quantity .. ") for " .. player.Name)
			return true
		end
	end

	-- Create new inventory entry
	local inventoryItem = {
		ItemName = rollResult.ItemName,
		Rarity = rollResult.Rarity,
		Description = rollResult.ItemDescription,
		ObtainedAt = rollResult.Timestamp,
		Equipped = false,
		Quantity = 1,
		IsCrafted = rollResult.IsCrafted or false -- Include IsCrafted field
	}

	table.insert(data.Inventory, inventoryItem)
	print("Added " .. rollResult.ItemName .. " to " .. player.Name .. "'s inventory. Total items: " .. #data.Inventory)

	-- Add to roll history (keep last 50 rolls)
	table.insert(data.RollHistory, 1, {
		ItemName = rollResult.ItemName,
		Rarity = rollResult.Rarity,
		Timestamp = rollResult.Timestamp
	})

	if #data.RollHistory &gt; 50 then
		table.remove(data.RollHistory)
	end

	data.TotalRolls = data.TotalRolls + 1

	return true
end

-- Check if player can roll (cooldown check)
function PlayerDataManager.CanRoll(player)
	local data = PlayerDataManager.GetData(player)

	if not data then
		return false, "No data found"
	end

	local RNGConfig = require(game.ReplicatedStorage:WaitForChild("RNGConfig"))
	local currentTime = os.time()
	local timeSinceLastRoll = currentTime - data.LastRollTime

	if timeSinceLastRoll &lt; RNGConfig.RollCooldown then
		local timeRemaining = RNGConfig.RollCooldown - timeSinceLastRoll
		return false, "Cooldown: " .. timeRemaining .. "s remaining"
	end

	return true, "Can roll"
end

-- Update last roll time
function PlayerDataManager.UpdateRollTime(player)
	local data = PlayerDataManager.GetData(player)

	if data then
		data.LastRollTime = os.time()
	end
end

-- Get player inventory
function PlayerDataManager.GetInventory(player)
	local data = PlayerDataManager.GetData(player)
	return data and data.Inventory or {}
end

-- Set player inventory (for crafting system)
function PlayerDataManager.SetInventory(player, inventory)
	local data = PlayerDataManager.GetData(player)

	if not data then
		warn("No data found for " .. player.Name)
		return false
	end

	-- Keep track of existing IsCrafted status
	local existingCraftedStatus = {}
	for _, item in ipairs(data.Inventory) do
		local key = item.ItemName .. "|" .. item.Rarity
		existingCraftedStatus[key] = item.IsCrafted or false
	end

	-- Convert dictionary back to array format
	local newInventory = {}
	for key, quantity in pairs(inventory) do
		local itemName, rarity = key:match("(.+)|(.+)")
		if itemName and rarity then
			-- Find description from RNGConfig
			local description = ""
			local RNGConfig = require(game.ReplicatedStorage:WaitForChild("RNGConfig"))
			for _, rarityData in ipairs(RNGConfig.Rarities) do
				if rarityData.Name == rarity then
					local items = RNGConfig.Items[rarity]
					if items then
						for _, item in ipairs(items) do
							if item.Name == itemName then
								description = item.Description
								break
							end
						end
					end
					break
				end
			end

			-- Check if item already exists in inventory
			local found = false
			for _, existingItem in ipairs(newInventory) do
				if existingItem.ItemName == itemName and existingItem.Rarity == rarity then
					existingItem.Quantity = quantity
					found = true
					break
				end
			end

			if not found then
				-- Preserve IsCrafted status from existing inventory
				local wasCrafted = existingCraftedStatus[key] or false
				table.insert(newInventory, {
					ItemName = itemName,
					Rarity = rarity,
					Description = description,
					Quantity = quantity,
					Equipped = false,
					IsCrafted = wasCrafted -- Preserve existing IsCrafted status
				})
			end
		end
	end

	data.Inventory = newInventory
	print("[PlayerDataManager] Set inventory for " .. player.Name .. " with " .. #newInventory .. " items")
	return true
end

-- Get player roll history
function PlayerDataManager.GetRollHistory(player)
	local data = PlayerDataManager.GetData(player)
	return data and data.RollHistory or {}
end

-- Add to roll history
function PlayerDataManager.AddToRollHistory(player, rollResult)
	local data = PlayerDataManager.GetData(player)

	if not data then
		return false
	end

	-- Add to roll history (keep last 50 rolls)
	table.insert(data.RollHistory, 1, {
		ItemName = rollResult.ItemName,
		Rarity = rollResult.Rarity,
		Timestamp = rollResult.Timestamp
	})

	if #data.RollHistory &gt; 50 then
		table.remove(data.RollHistory)
	end

	return true
end

-- Equip an item
function PlayerDataManager.EquipItem(player, itemIndex)
	print("[PlayerDataManager] EquipItem called for player:", player.Name, "index:", tostring(itemIndex))
	local data = PlayerDataManager.GetData(player)

	if not data then
		print("[PlayerDataManager] No data found for player")
		return false, "No data found"
	end

	if not data.Inventory[itemIndex] then
		print("[PlayerDataManager] Invalid item index:", itemIndex, "Inventory size:", #data.Inventory)
		return false, "Invalid item index"
	end

	-- Unequip all items
	for _, item in ipairs(data.Inventory) do
		item.Equipped = false
	end

	-- Equip selected item
	data.Inventory[itemIndex].Equipped = true
	data.EquippedIndex = itemIndex

	print("[PlayerDataManager] Equipped item at index " .. itemIndex .. " for " .. player.Name)

	-- Return a complete item object with all required fields
	local equippedItem = data.Inventory[itemIndex]
	local returnData = {
		ItemName = equippedItem.ItemName,
		Rarity = equippedItem.Rarity,
		Description = equippedItem.Description or "No description",
		IsCrafted = equippedItem.IsCrafted or false
	}
	print("[PlayerDataManager] Returning item data:", returnData.ItemName, returnData.Rarity, "IsCrafted:", returnData.IsCrafted)
	return true, returnData
end

-- Remove item from inventory (with stacking support)
function PlayerDataManager.RemoveItemFromInventory(player, itemIndex)
	local data = PlayerDataManager.GetData(player)

	if not data or not data.Inventory[itemIndex] then
		return false
	end

	local item = data.Inventory[itemIndex]
	local quantity = item.Quantity or 1

	if quantity &gt; 1 then
		-- Decrement quantity instead of removing
		item.Quantity = quantity - 1
		print("Decremented " .. item.ItemName .. " to x" .. item.Quantity .. " for " .. player.Name)
		return true
	end

	-- Check if the item being deleted is equipped
	local wasEquipped = item.Equipped

	-- Remove the item (quantity is 1)
	table.remove(data.Inventory, itemIndex)

	-- If the deleted item was equipped, update equipped index
	if wasEquipped then
		data.EquippedIndex = nil
	elseif data.EquippedIndex and data.EquippedIndex &gt; itemIndex then
		-- If an item after the deleted one was equipped, adjust the index
		data.EquippedIndex = data.EquippedIndex - 1
	end

	print("Removed item at index " .. itemIndex .. " from " .. player.Name .. "'s inventory. Remaining items: " .. #data.Inventory)

	return true
end

-- Get equipped item
function PlayerDataManager.GetEquippedItem(player)
	local data = PlayerDataManager.GetData(player)

	if not data then
		return nil
	end

	for _, item in ipairs(data.Inventory) do
		if item.Equipped then
			return item
		end
	end

	return nil
end

-- Get player currency
function PlayerDataManager.GetCurrency(player)
	local data = PlayerDataManager.GetData(player)
	return data and data.Currency or 0
end

-- Add currency
function PlayerDataManager.AddCurrency(player, amount)
	local data = PlayerDataManager.GetData(player)

	if not data then
		return false
	end

	data.Currency = data.Currency + amount
	return true
end

-- Remove currency (returns true if successful, false if not enough)
function PlayerDataManager.RemoveCurrency(player, amount)
	local data = PlayerDataManager.GetData(player)

	if not data or data.Currency &lt; amount then
		return false
	end

	data.Currency = data.Currency - amount
	return true
end

-- Get total rolls
function PlayerDataManager.GetTotalRolls(player)
	local data = PlayerDataManager.GetData(player)
	return data and data.TotalRolls or 0
end

return PlayerDataManager</string>
        </Properties>
      </Item>
      <Item class="Script" referent="11">
        <Properties>
          <string name="Name">RNGServer</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local RNGSystem = require(ReplicatedStorage:WaitForChild("RNGSystem"))
local PlayerDataManager = require(script.Parent:WaitForChild("PlayerDataManager"))

local RemoteEventsFolder = ReplicatedStorage:WaitForChild("RemoteEvents")
local RollEvent = RemoteEventsFolder:WaitForChild("RollEvent")
local InventoryUpdateEvent = RemoteEventsFolder:WaitForChild("InventoryUpdateEvent")
local EquipEvent = RemoteEventsFolder:WaitForChild("EquipEvent")
local DeleteEvent = RemoteEventsFolder:WaitForChild("DeleteEvent")
local GetInventoryFunction = RemoteEventsFolder:WaitForChild("GetInventoryFunction")

-- Create GetEquippedFunction if it doesn't exist
local GetEquippedFunction = RemoteEventsFolder:FindFirstChild("GetEquippedFunction")
if not GetEquippedFunction then
	GetEquippedFunction = Instance.new("RemoteFunction")
	GetEquippedFunction.Name = "GetEquippedFunction"
	GetEquippedFunction.Parent = RemoteEventsFolder
end

-- Create BulkDeleteEvent if it doesn't exist
local BulkDeleteEvent = RemoteEventsFolder:FindFirstChild("BulkDeleteEvent")
if not BulkDeleteEvent then
	BulkDeleteEvent = Instance.new("RemoteEvent")
	BulkDeleteEvent.Name = "BulkDeleteEvent"
	BulkDeleteEvent.Parent = RemoteEventsFolder
end

local function sendFullUpdate(player)
	local data = PlayerDataManager.GetData(player)
	if not data then return end

	local copy = {
		Inventory = {},
		TotalRolls = #data.RollHistory,
		Currency = data.Currency or 0,
	}

	for i, item in ipairs(data.Inventory) do
		copy.Inventory[i] = {
			ItemName = item.ItemName,
			Rarity = item.Rarity,
			Description = item.Description,
			Equipped = (data.EquippedIndex == i),
			Quantity = item.Quantity or 1,
			OriginalIndex = i,
			IsCrafted = item.IsCrafted or false
		}
	end

	InventoryUpdateEvent:FireClient(player, copy)
end

_G.sendFullUpdate = sendFullUpdate

Players.PlayerAdded:Connect(function(player)
	PlayerDataManager.LoadData(player)
	sendFullUpdate(player)
end)

Players.PlayerRemoving:Connect(function(player)
	PlayerDataManager.SaveData(player)
end)

-- Auto-save every 60 seconds
task.spawn(function()
	while true do
		task.wait(60)
		for _, player in Players:GetPlayers() do
			PlayerDataManager.SaveData(player)
		end
	end
end)

RollEvent.OnServerEvent:Connect(function(player)
	local canRoll, msg = PlayerDataManager.CanRoll(player)
	if not canRoll then
		RollEvent:FireClient(player, {Success=false, Message=msg})
		return
	end

	local luckMultiplier = 1
	local equippedItem = PlayerDataManager.GetEquippedItem(player)
	if equippedItem and equippedItem.IsCrafted then
		local RNGConfig = require(ReplicatedStorage:WaitForChild("RNGConfig"))
		for _, rarity in ipairs(RNGConfig.Rarities) do
			if rarity.Name == equippedItem.Rarity then
				luckMultiplier = rarity.LuckBuff or 1
				break
			end
		end
	end

	local rollResult = RNGSystem.PerformRollWithLuck(luckMultiplier)

	if not rollResult or not rollResult.ItemName then
		RollEvent:FireClient(player, {Success=false, Message="Invalid roll result"})
		return
	end

	PlayerDataManager.UpdateRollTime(player)

	local normalizedItem = {
		ItemName = rollResult.ItemName,
		Rarity = rollResult.Rarity,
		Description = rollResult.ItemDescription,
		Equipped = false,
		ObtainedAt = rollResult.Timestamp or os.time()
	}

	PlayerDataManager.AddItemToInventory(player, normalizedItem)
	PlayerDataManager.AddToRollHistory(player, normalizedItem)

	RollEvent:FireClient(player, {
		Success = true,
		Result = rollResult
	})

	sendFullUpdate(player)
end)

EquipEvent.OnServerEvent:Connect(function(player, index)
	local success, equippedItem = PlayerDataManager.EquipItem(player, index)
	if success then
		local fullEquippedItem = PlayerDataManager.GetEquippedItem(player)
		EquipEvent:FireClient(player, {Success = true, EquippedItem = fullEquippedItem})
		local EquipEffectsEvent = RemoteEventsFolder:FindFirstChild("EquipEffectsEvent")
		if EquipEffectsEvent then
			EquipEffectsEvent:FireAllClients({Player = player, Action = "Equip", ItemData = fullEquippedItem})
		end
	else
		EquipEvent:FireClient(player, {Success = false, Message = equippedItem or "Failed to equip item"})
	end
	sendFullUpdate(player)
end)

DeleteEvent.OnServerEvent:Connect(function(player, index)
	local success = PlayerDataManager.RemoveItemFromInventory(player, index)
	if success then
		sendFullUpdate(player)
	end
end)

BulkDeleteEvent.OnServerEvent:Connect(function(player, indices)
	if type(indices) ~= "table" or #indices == 0 then return end
	table.sort(indices, function(a, b) return a > b end)
	for _, index in ipairs(indices) do
		PlayerDataManager.RemoveItemFromInventory(player, index)
	end
	sendFullUpdate(player)
end)

GetInventoryFunction.OnServerInvoke = function(player)
	local data = PlayerDataManager.GetData(player)
	if not data then return {} end
	local inventoryCopy = {}
	for i, item in ipairs(data.Inventory) do
		inventoryCopy[i] = {
			ItemName = item.ItemName,
			Rarity = item.Rarity,
			Description = item.Description,
			Equipped = (data.EquippedIndex == i),
			Quantity = item.Quantity or 1,
			OriginalIndex = i,
			IsCrafted = item.IsCrafted or false
		}
	end
	return inventoryCopy
end

local GetInventoryForCraftingFunction = RemoteEventsFolder:WaitForChild("GetInventoryForCraftingFunction")
GetInventoryForCraftingFunction.OnServerInvoke = function(player)
	local data = PlayerDataManager.GetData(player)
	if not data then return {} end
	local groupedInventory = {}
	for _, item in ipairs(data.Inventory) do
		local key = item.ItemName .. "|" .. item.Rarity
		groupedInventory[key] = (groupedInventory[key] or 0) + (item.Quantity or 1)
	end
	return groupedInventory
end

GetEquippedFunction.OnServerInvoke = function(player, targetPlayer)
	local queryPlayer = targetPlayer or player
	local data = PlayerDataManager.GetData(queryPlayer)
	if not data then return nil end
	if data.EquippedIndex and data.Inventory[data.EquippedIndex] then
		local item = data.Inventory[data.EquippedIndex]
		return {ItemName = item.ItemName, Rarity = item.Rarity, Description = item.Description, IsCrafted = item.IsCrafted or false}
	end
	return nil
end

print("[RNGServer] Initialized")
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="12">
        <Properties>
          <string name="Name">TestFloatingSimple</string>
          <string name="Source">--[[
    Simple Floating Test
    Run this to test the floating effect
    Usage: In the command bar, run:
    game.ServerScriptService.TestFloatingSimple:Test()
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local TestFloatingSimple = {}

function TestFloatingSimple.Test(playerName)
	-- Find the player
	local player
	if playerName then
		player = Players:FindFirstChild(playerName)
	else
		-- Get the first player in the game
		local allPlayers = Players:GetPlayers()
		if #allPlayers &gt; 0 then
			player = allPlayers[1]
		end
	end
	
	if not player then
		warn("[TestFloatingSimple] No player found! Make sure you're in Play Mode.")
		return nil
	end
	
	local character = player.Character
	if not character then
		warn("[TestFloatingSimple] No character found for " .. player.Name .. "! Please spawn your character first.")
		return nil
	end
	
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if not hrp then
		warn("[TestFloatingSimple] No HumanoidRootPart found!")
		return nil
	end
	
	print("[TestFloatingSimple] Starting floating test for " .. player.Name .. "...")
	print("[TestFloatingSimple] You should float 3 studs above the ground.")
	print("[TestFloatingSimple] Press SPACE to stop floating.")
	
	local connection
	local isFloating = true
	
	connection = RunService.Heartbeat:Connect(function()
		if not character.Parent or not isFloating then
			connection:Disconnect()
			return
		end
		
		-- Get current HRP (in case it was replaced)
		local currentHrp = character:FindFirstChild("HumanoidRootPart")
		if not currentHrp then
			connection:Disconnect()
			return
		end
		
		-- Raycast down to find ground
		local rayParams = RaycastParams.new()
		rayParams.FilterType = Enum.RaycastFilterType.Exclude
		rayParams.FilterDescendantsInstances = {character}
		
		local rayResult = workspace:Raycast(
			currentHrp.Position,
			Vector3.new(0, -100, 0),
			rayParams
		)
		
		local groundY = rayResult and rayResult.Position.Y or 0
		local targetY = groundY + 3
		
		-- Apply upward velocity
		local velocityY = (targetY - currentHrp.Position.Y) * 10
		currentHrp.AssemblyLinearVelocity = Vector3.new(
			currentHrp.AssemblyLinearVelocity.X,
			velocityY,
			currentHrp.AssemblyLinearVelocity.Z
		)
	end)
	
	-- Listen for jump to stop
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.Jumping:Connect(function()
			isFloating = false
			print("[TestFloatingSimple] Floating stopped!")
		end)
	end
	
	return connection
end

return TestFloatingSimple</string>
        </Properties>
      </Item>
      <Item class="Script" referent="13">
        <Properties>
          <string name="Name">UpdateCraftedDescriptionsOnJoin</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- UpdateCraftedDescriptionsOnJoin (Server Script)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local CraftingRecipes = require(ReplicatedStorage:WaitForChild("CraftingRecipes"))
local PlayerDataManager = require(script.Parent:WaitForChild("PlayerDataManager"))

-- Build lookup table once
local craftedItemDescriptions = {}
for _, recipe in ipairs(CraftingRecipes.Recipes) do
	local key = recipe.Result.Name .. "|" .. recipe.Result.Rarity
	craftedItemDescriptions[key] = recipe.Result.Description
end

local function updatePlayerCraftedItems(player)
	local data = PlayerDataManager.GetData(player)
	if not data or not data.Inventory then return end

	local updatedCount = 0
	for _, item in ipairs(data.Inventory) do
		if item.IsCrafted then
			local key = item.ItemName .. "|" .. item.Rarity
			local newDesc = craftedItemDescriptions[key]
			if newDesc and item.Description ~= newDesc then
				item.Description = newDesc
				updatedCount += 1
			end
		end
	end

	if updatedCount > 0 then
		PlayerDataManager.SaveData(player)
	end
end

for _, player in Players:GetPlayers() do
	updatePlayerCraftedItems(player)
end

Players.PlayerAdded:Connect(function(player)
	task.wait(1)
	updatePlayerCraftedItems(player)
end)

print("[UpdateCraftedDescriptionsOnJoin] Initialized")
]]></string>
