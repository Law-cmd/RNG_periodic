        <Item class="ModuleScript" referent="17">
          <Properties>
            <string name="Name">EquipEffectsVisualizer.local</string>
            <string name="Source">--[[
	Equip Effects Visualizer
	Creates equip effects on other players' characters
	This script runs on each client and shows effects for all players
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local RemoteEventsFolder = ReplicatedStorage:WaitForChild("RemoteEvents")
local EquipEffectsEvent = RemoteEventsFolder:WaitForChild("EquipEffectsEvent")

-- Require the EquipEffects module to use its effect creation functions
local EquipEffects = require(script.Parent:WaitForChild("EquipEffects"))

-- Track effects for each player
local activeEffects = {}

-- Create effects on a player's character
local function createEffectsOnPlayer(player, itemData)
	local character = player.Character
	if not character then return end

	-- Remove existing effects for this player
	if activeEffects[player.UserId] then
		local effects = EquipEffects.ActiveEffects[player.UserId]
		if effects then
			local function destroy(v)
				if typeof(v) == "Instance" then v:Destroy() end
			end
			if effects.Particles then destroy(effects.Particles) end
			if effects.Nucleus then
				destroy(effects.Nucleus.Core)
				for _, n in ipairs(effects.Nucleus.Nucleons) do destroy(n) end
			end
			if effects.Shells then
				for _, shell in ipairs(effects.Shells) do
					for _, e in ipairs(shell) do destroy(e) end
				end
			end
			if effects.Rings then
				for _, r in ipairs(effects.Rings) do destroy(r) end
			end
			EquipEffects.ActiveEffects[player.UserId] = nil
		end
	end

	-- Create new effects
	EquipEffects.EquipElement(player, itemData)
	activeEffects[player.UserId] = itemData
end

-- Handle equip effects event
EquipEffectsEvent.OnClientEvent:Connect(function(data)
	local player = data.Player
	local action = data.Action
	local itemData = data.ItemData

	if action == "Equip" then
		-- Don't create effects on our own character (handled by RNGClient)
		if player ~= Players.LocalPlayer then
			createEffectsOnPlayer(player, itemData)
		end
	elseif action == "Unequip" then
		if player ~= Players.LocalPlayer then
			if activeEffects[player.UserId] then
				local effects = EquipEffects.ActiveEffects[player.UserId]
				if effects then
					local function destroy(v)
						if typeof(v) == "Instance" then v:Destroy() end
					end
					if effects.Particles then destroy(effects.Particles) end
					if effects.Nucleus then
						destroy(effects.Nucleus.Core)
						for _, n in ipairs(effects.Nucleus.Nucleons) do destroy(n) end
					end
					if effects.Shells then
						for _, shell in ipairs(effects.Shells) do
							for _, e in ipairs(shell) do destroy(e) end
						end
					end
					if effects.Rings then
						for _, r in ipairs(effects.Rings) do destroy(r) end
					end
					EquipEffects.ActiveEffects[player.UserId] = nil
				end
				activeEffects[player.UserId] = nil
			end
		end
	end
end)

-- Handle player joining (show their equipped item if they have one)
Players.PlayerAdded:Connect(function(player)
	task.wait(2) -- Wait for character to load

	if player ~= Players.LocalPlayer then
		-- Request equipped item from server
		local GetEquippedFunction = RemoteEventsFolder:FindFirstChild("GetEquippedFunction")
		if GetEquippedFunction then
			local success, equippedItem = pcall(function()
				return GetEquippedFunction:InvokeServer(player)
			end)

			if success and equippedItem then
				createEffectsOnPlayer(player, equippedItem)
			end
		end
	end
end)

-- Handle player leaving
Players.PlayerRemoving:Connect(function(player)
	if activeEffects[player.UserId] then
		activeEffects[player.UserId] = nil
	end
end)

-- Handle character respawn for existing players
for _, player in ipairs(Players:GetPlayers()) do
	if player ~= Players.LocalPlayer then
		player.CharacterAdded:Connect(function(character)
			task.wait(1)
			if activeEffects[player.UserId] then
				createEffectsOnPlayer(player, activeEffects[player.UserId])
			end
		end)
	end
end

print("[EquipEffectsVisualizer] Initialized")</string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="18">
          <Properties>
            <string name="Name">MoneyDisplay.local</string>
            <string name="Source">--[[
	Money Display
	Shows the player's current money on screen
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Wait for RemoteEvents
local RemoteEventsFolder = ReplicatedStorage:WaitForChild("RemoteEvents")
local MoneyUpdateEvent = RemoteEventsFolder:WaitForChild("MoneyUpdateEvent")

-- Create money display GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "MoneyDisplayGui"
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.DisplayOrder = 50 -- Show above other GUIs
screenGui.Parent = playerGui

-- Money frame
local moneyFrame = Instance.new("Frame")
moneyFrame.Name = "MoneyFrame"
moneyFrame.Size = UDim2.new(0, 200, 0, 50)
moneyFrame.Position = UDim2.new(1, -210, 0, 10)
moneyFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
moneyFrame.BorderSizePixel = 0
moneyFrame.Parent = screenGui

local moneyCorner = Instance.new("UICorner")
moneyCorner.CornerRadius = UDim.new(0, 10)
moneyCorner.Parent = moneyFrame

local moneyStroke = Instance.new("UIStroke")
moneyStroke.Color = Color3.fromRGB(255, 215, 0) -- Gold color
moneyStroke.Thickness = 2
moneyStroke.Parent = moneyFrame

-- Money icon
local moneyIcon = Instance.new("TextLabel")
moneyIcon.Size = UDim2.new(0, 40, 1, 0)
moneyIcon.BackgroundTransparency = 1
moneyIcon.Text = "💰"
moneyIcon.TextSize = 24
moneyIcon.Font = Enum.Font.GothamBold
moneyIcon.Parent = moneyFrame

-- Money label
local moneyLabel = Instance.new("TextLabel")
moneyLabel.Name = "MoneyLabel"
moneyLabel.Size = UDim2.new(1, -50, 1, 0)
moneyLabel.Position = UDim2.new(0, 40, 0, 0)
moneyLabel.BackgroundTransparency = 1
moneyLabel.Text = "$0 (+$1/s)"
moneyLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
moneyLabel.TextSize = 18
moneyLabel.Font = Enum.Font.GothamBold
moneyLabel.TextXAlignment = Enum.TextXAlignment.Left
moneyLabel.Parent = moneyFrame

-- Track current income rate
local currentIncomeRate = 1

-- Update money display
local function updateMoneyDisplay(amount, incomeRate)
	if incomeRate then
		currentIncomeRate = incomeRate
	end
	moneyLabel.Text = "$" .. tostring(amount) .. " (+$" .. tostring(currentIncomeRate) .. "/s)"
end

-- Listen for money updates from server
MoneyUpdateEvent.OnClientEvent:Connect(function(data)
	if data and data.Total ~= nil then
		updateMoneyDisplay(data.Total, data.IncomeRate)
	end
end)

-- Request initial money from server
task.spawn(function()
	task.wait(1)
	local GetMoneyFunction = RemoteEventsFolder:FindFirstChild("GetMoneyFunction")
	if GetMoneyFunction then
		local success, currentMoney = pcall(function()
			return GetMoneyFunction:InvokeServer()
		end)
		if success and currentMoney then
			updateMoneyDisplay(currentMoney)
		end
	end
end)

print("[MoneyDisplay] Initialized")</string>
          </Properties>
